<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Backgrounds ─────────────────────────────────────── -->
    <color name="bg_dark">#1A1724</color>
    <color name="bg_darkest">#131020</color>
    <color name="surface">#231F32</color>
    <color name="surface2">#2C2840</color>
    <color name="surface_dark">#0D0B14</color>
    <color name="map_bg">#161E2C</color>

    <!-- ── Borders / dividers ──────────────────────────────── -->
    <color name="border">#3A3550</color>

    <!-- ── Text ───────────────────────────────────────────── -->
    <color name="text_primary">#F2F0FA</color>
    <color name="text_muted">#8A83A8</color>
    <color name="text_dim">#5C566E</color>

    <!-- ── Accent: Purple (principal) ─────────────────────── -->
    <!-- oklch(0.65 0.22 280) ≈ #7B5EEA -->
    <color name="purple_primary">#7B5EEA</color>
    <color name="purple_soft">#7B5EEA26</color>    <!-- 15% alpha -->
    <color name="purple_mid">#7B5EEA59</color>     <!-- 35% alpha -->

    <!-- ── Accent: Green ──────────────────────────────────── -->
    <!-- oklch(0.72 0.18 155) ≈ #2ECC8A -->
    <color name="green_primary">#2ECC8A</color>
    <color name="green_soft">#2ECC8A26</color>

    <!-- ── Accent: Orange ─────────────────────────────────── -->
    <!-- oklch(0.72 0.18 55) ≈ #E8933A -->
    <color name="orange_primary">#E8933A</color>

    <!-- ── Accent: Red / heart rate ───────────────────────── -->
    <!-- oklch(0.65 0.22 22) ≈ #E05050 -->
    <color name="red_primary">#E05050</color>

    <!-- ── Accent: Yellow ─────────────────────────────────── -->
    <!-- oklch(0.82 0.16 85) ≈ #D4B840 -->
    <color name="yellow_primary">#D4B840</color>

    <!-- ── Accent: Blue (agua) ────────────────────────────── -->
    <!-- oklch(0.65 0.18 220) ≈ #3A8FD4 -->
    <color name="blue_primary">#3A8FD4</color>

    <!-- Material theme obligatorios -->
    <color name="colorPrimary">@color/purple_primary</color>
    <color name="colorPrimaryVariant">#5A3EC8</color>
    <color name="colorOnPrimary">#FFFFFF</color>
    <color name="colorSecondary">@color/green_primary</color>
    <color name="colorOnSecondary">#000000</color>
    <color name="colorSurface">@color/surface</color>
    <color name="colorOnSurface">@color/text_primary</color>
    <color name="colorBackground">@color/bg_dark</color>
    <color name="colorOnBackground">@color/text_primary</color>
    <color name="colorError">@color/red_primary</color>
    <color name="colorOnError">#FFFFFF</color>

</resources>
