<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Tema base de la app (dark) ─────────────────────── -->
    <style name="Theme.FocusFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Colores principales -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <item name="colorSecondary">@color/green_primary</item>
        <item name="colorSecondaryVariant">@color/green_primary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>

        <!-- Fondo y superficie -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/red_primary</item>
        <item name="colorOnError">@android:color/white</item>

        <!-- Status bar / navigation bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Tipografía -->
        <!-- Shapes globales -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Elevación en dark mode -->
        <item name="elevationOverlayEnabled">true</item>
        <item name="elevationOverlayColor">@color/purple_primary</item>
    </style>

    <!-- ── Tema Splash ─────────────────────────────────────── -->
    <style name="Theme.FocusFlow.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_darkest</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.FocusFlow</item>
    </style>

    <!-- ── Shapes ──────────────────────────────────────────── -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- ── Botón primario ──────────────────────────────────── -->
    <style name="Widget.FocusFlow.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ── Botón outlined ─────────────────────────────────── -->
    <style name="Widget.FocusFlow.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">15sp</item>
        <item name="strokeColor">@color/purple_mid</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <!-- ── TextAppearance TopBar ───────────────────────────── -->
    <style name="TextAppearance.TopBar" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- ── Card estándar ──────────────────────────────────── -->
    <style name="Widget.FocusFlow.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- ── TextInput outlined ─────────────────────────────── -->
    <style name="Widget.FocusFlow.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/text_dim</item>
        <item name="android:textColorHint">@color/text_dim</item>
    </style>

    <!-- ── Chip ───────────────────────────────────────────── -->
    <style name="Widget.FocusFlow.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="chipBackgroundColor">@color/surface</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="checkedIconVisible">false</item>
    </style>

</resources>
