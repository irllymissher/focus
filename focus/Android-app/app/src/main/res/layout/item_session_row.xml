<?xml version="1.0" encoding="utf-8"?>
<!-- Item de fila en la lista de sesiones del resumen -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="10dp">

        <!-- Número de sesión -->
        <TextView
            android:id="@+id/tv_session_number"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="1"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textColor="@color/purple_primary"
            android:gravity="center"
            android:background="@drawable/bg_session_badge"
            android:layout_marginEnd="12dp" />

        <!-- Nombre + detalle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_session_goal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin objetivo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_session_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90 min · Energía alta"
                android:textSize="12sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Check completado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="16sp"
            android:textColor="@color/green_primary" />
    </LinearLayout>

    <View
        android:id="@+id/v_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

</LinearLayout>
