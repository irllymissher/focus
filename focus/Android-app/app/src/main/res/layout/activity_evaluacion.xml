<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla 3: Evaluación de estado -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="22dp"
        android:paddingBottom="32dp">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/text_muted"
            app:title="@string/screen_evaluacion"
            app:titleTextColor="@color/text_muted"
            app:titleTextAppearance="@style/TextAppearance.TopBar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Tarjeta: Nivel de estrés -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/stress_level"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_stress_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textColor="@color/purple_primary" />
                </LinearLayout>

                <!-- Slider 0-10 -->
                <SeekBar
                    android:id="@+id/seekbar_stress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:max="10"
                    android:progress="5"
                    android:progressTint="@color/purple_primary"
                    android:thumbTint="@color/purple_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="11sp" android:textColor="@color/text_dim" />
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="10" android:textSize="11sp" android:textColor="@color/text_dim" />
                </LinearLayout>

                <!-- Emojis indicadores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="😌" android:textSize="18sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🙂" android:textSize="18sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="😐" android:textSize="18sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="😤" android:textSize="18sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🤯" android:textSize="18sp" android:gravity="center" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta: Dibujo emocional -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_drawing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_stress"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/drawing_label"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Botón borrar -->
                    <TextView
                        android:id="@+id/tv_clear_canvas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_clear"
                        android:textSize="11sp"
                        android:textColor="@color/text_dim"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <com.focusflow.app.views.DrawingView
                    android:id="@+id/drawing_canvas"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_drawing_area" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/drawing_hint"
                    android:textSize="11sp"
                    android:textColor="@color/text_dim"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta: BPM -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bpm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_drawing"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <!-- Ícono pulso (animado con ScaleAnimation o Lottie) -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp">

                    <View
                        android:id="@+id/v_pulse_ring"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_pulse_ring" />

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_heart_circle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="♥"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:textColor="@android:color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bpm_label"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_bpm_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="78"
                            android:textSize="28sp"
                            android:fontFamily="monospace"
                            android:textStyle="bold"
                            android:textColor="@color/red_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" PPM"
                            android:textSize="13sp"
                            android:textColor="@color/text_dim"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón calcular -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calculate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_calculate"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/purple_primary"
            app:cornerRadius="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/card_bpm"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
