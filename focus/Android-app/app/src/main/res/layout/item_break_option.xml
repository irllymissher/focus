<?xml version="1.0" encoding="utf-8"?>
<!-- Item de lista: opción de descanso (para RecyclerView en activity_descanso) -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_break_option"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Ícono -->
        <TextView
            android:id="@+id/tv_break_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⚡"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="14dp" />

        <!-- Texto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_break_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Energía alta"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_break_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actividad física"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Chip recomendado (GONE por defecto) -->
        <TextView
            android:id="@+id/tv_recommended_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recommended"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_badge_green"
            android:visibility="gone" />

        <!-- Check seleccionado (GONE por defecto) -->
        <TextView
            android:id="@+id/tv_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="18sp"
            android:textColor="@color/purple_primary"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
