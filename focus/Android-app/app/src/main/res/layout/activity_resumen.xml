<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla 5: Resumen del día -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="22dp"
        android:paddingBottom="32dp">

        <!-- Toolbar sin botón atrás -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/screen_resumen"
            app:titleTextColor="@color/text_muted"
            app:titleTextAppearance="@style/TextAppearance.TopBar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Tarjeta gráfico circular + leyenda -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <!--
                    Gráfico de tarta custom (PieChartView extends View).
                    Segmentos: Energía, Estrés, Cansancio.
                    Implementar con Canvas.drawArc() en onDraw().
                    Alternativamente usar MPAndroidChart: PieChart.
                -->
                <com.focusflow.app.views.PieChartView
                    android:id="@+id/pie_chart"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginEnd="20dp" />
                <!--
                    Si usas MPAndroidChart, reemplaza con:
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart"
                        android:layout_width="160dp"
                        android:layout_height="160dp" />
                -->

                <!-- Leyenda -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Energía -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@drawable/bg_dot_green" android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Energía"
                            android:textSize="13sp" android:textColor="@color/text_primary" />
                        <TextView android:id="@+id/tv_energy_pct" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="65%"
                            android:textSize="14sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/green_primary" />
                    </LinearLayout>

                    <!-- Estrés -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@drawable/bg_dot_purple" android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Estrés"
                            android:textSize="13sp" android:textColor="@color/text_primary" />
                        <TextView android:id="@+id/tv_stress_pct" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="20%"
                            android:textSize="14sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/purple_primary" />
                    </LinearLayout>

                    <!-- Cansancio -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@drawable/bg_dot_orange" android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Cansancio"
                            android:textSize="13sp" android:textColor="@color/text_primary" />
                        <TextView android:id="@+id/tv_tiredness_pct" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="15%"
                            android:textSize="14sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/orange_primary" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta: bloques completados -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_chart"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/completed_blocks"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="14dp" />

                <!-- RecyclerView con lista de sesiones completadas -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_session_row"
                    xmlns:tools="http://schemas.android.com/tools" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón volver al inicio -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_to_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_back_to_start"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/purple_primary"
            app:cornerRadius="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/card_sessions"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
