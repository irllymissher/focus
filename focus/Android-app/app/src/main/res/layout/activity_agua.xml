<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla 4.4a: Agua — Nivel 4 (Agotamiento severo) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingHorizontal="22dp">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/text_muted"
        app:title="@string/screen_agua"
        app:titleTextColor="@color/text_muted"
        app:titleTextAppearance="@style/TextAppearance.TopBar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Título -->
    <TextView
        android:id="@+id/tv_water_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/water_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Descripción -->
    <TextView
        android:id="@+id/tv_water_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/water_desc"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_water_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Vasos ilustrados -->
    <LinearLayout
        android:id="@+id/ll_glasses"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_water_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Vaso 1 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:layout_marginEnd="24dp">
            <ImageView
                android:id="@+id/iv_glass1"
                android:layout_width="60dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_glass_water"
                android:contentDescription="@string/glass_1" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/glass_1" android:textSize="12sp"
                android:textColor="@color/text_muted" android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Vaso 2 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center">
            <ImageView
                android:id="@+id/iv_glass2"
                android:layout_width="60dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_glass_water"
                android:contentDescription="@string/glass_2" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/glass_2" android:textSize="12sp"
                android:textColor="@color/text_muted" android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tarjeta progreso diario -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_water_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/ll_glasses"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/daily_goal"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/pb_water"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressTint="@color/blue_primary"
                android:progressBackgroundTint="@color/border"
                android:max="8"
                android:progress="3" />

            <TextView
                android:id="@+id/tv_water_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 / 8 vasos hoy"
                android:textSize="12sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Botón completado -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_water_done"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_done_next"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="@color/blue_primary"
        app:cornerRadius="16dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
